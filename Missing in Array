class Solution {
  public:
    int missingNum(vector<int>& arr) {
        // total numbers should be size+1
        int n = arr.size() + 1;
        long long sum = 0;

        // sum of all elements in the array
        for (int i = 0; i < arr.size(); i++) {
            sum += arr[i];
        }

        // sum of first n natural numbers
        long long ans = (long long)n * (n + 1) / 2;

        return (int)(ans - sum);
    }
};
